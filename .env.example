PORT=3001
NODE_ENV=development

# ─── Hedera Treasury (3-Account Structure) ───
# Primary account (legacy fallback — use specific treasury accounts below)
HEDERA_ACCOUNT_ID=0.0.10357025
HEDERA_PRIVATE_KEY=302e020100300506032b6570...
HEDERA_NETWORK=mainnet

# Operations Treasury — platform fees, subscriptions, penalty forfeitures
HEDERA_OPS_ACCOUNT_ID=0.0.10357023
HEDERA_OPS_PRIVATE_KEY=302e...

# Trust Deposit Escrow — agent trust deposits (segregated customer funds)
HEDERA_ESCROW_ACCOUNT_ID=0.0.10357024
HEDERA_ESCROW_PRIVATE_KEY=302e...

# Gas Wallet — HBAR for HCS transaction fees
HEDERA_GAS_ACCOUNT_ID=0.0.10357025
HEDERA_GAS_PRIVATE_KEY=302e...

# BorealisMark Audit Topic (auto-created on first audit if not set)
HEDERA_AUDIT_TOPIC_ID=

# Hedera USDC Payments — Native Circle USDC (NOT Hashport bridged)
# All 3 treasury accounts associated with this token
HEDERA_USDC_TOKEN_ID=0.0.456858
HEDERA_MIRROR_NODE_URL=https://mainnet.mirrornode.hedera.com

# API Security
API_MASTER_KEY=borealismark-dev-key
JWT_SECRET=change-this-to-a-random-64-char-string-in-production

# ─── Database (Turso for production, SQLite for dev) ───
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token
# Falls back to local SQLite if not set
DB_PATH=./borealismark.db

# ─── Stripe (Live Mode) ───
STRIPE_SECRET_KEY=sk_live_XXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXX

# Frontend URL (for checkout redirect and password reset links)
FRONTEND_URL=https://borealisterminal.com

# Resend Email (for password reset emails from support@borealisprotocol.ai)
RESEND_API_KEY=re_XXXXXXX

# ─── Cloudflare R2 Image Hosting ───
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=borealismark-images
R2_PUBLIC_URL=https://images.borealismark.com
